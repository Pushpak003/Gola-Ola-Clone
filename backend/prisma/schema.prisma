generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  CAPTAIN
}

enum VehicleType {
  BIKE
  AUTO
  MINI
  SEDAN
  SUV
}

enum RideStatus {
  SEARCHING
  ACCEPTED
  ARRIVING
  STARTED
  COMPLETED
  CANCELLED
}

model User {
  id          String   @id @default(uuid())

  fullname    String?

  phone       String   @unique

  rides       Ride[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
model Captain {
  id              String       @id @default(uuid())

  fullname        String

  phone           String       @unique

  vehicleType     VehicleType

  vehicleNumber   String       @unique

  isOnline        Boolean      @default(false)

  currentLat      Float?
  currentLng      Float?

  rides           Ride[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Ride {
  id                 String       @id @default(uuid())

  userId             String
  captainId          String?

  user               User         @relation(fields: [userId], references: [id])
  captain            Captain?     @relation(fields: [captainId], references: [id])

  pickup             String
  destination        String

  pickupLat          Float
  pickupLng          Float

  destinationLat     Float
  destinationLng     Float

  distance           Float
  duration           Int

  fare               Float

  vehicleType        VehicleType

  status             RideStatus   @default(SEARCHING)

  otp                String?

  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}
model OTP {
  id          String   @id @default(uuid())

  phone       String

  code        String

  expiresAt   DateTime

  createdAt   DateTime @default(now())
}